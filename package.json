{
  "name": "hoc-hung-khoi",
  "version": "0.1.0",
  "productName": "Học Hứng Khởi Tiểu Học",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:web": "cross-env VITE_WEB=true tsc && vite build",
    "preview": "vite preview --host",
    "preview:local": "npm run build && vite preview --host",
    "build:strict": "npm run data:check && npm run build",
    "electron:dev": "cross-env ELECTRON_RUN_AS_NODE=0 VITE_DEV_SERVER_URL=http://127.0.0.1:5190 concurrently \"vite --host 127.0.0.1 --port 5190 --strictPort\" \"wait-on http://127.0.0.1:5190 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "db:seed": "node scripts/seed.js",
    "data:audit": "tsx scripts/audit-curriculum.ts",
    "data:check": "cross-env STRICT_DATA_CHECK=1 tsx scripts/audit-curriculum.ts",
    "data:plan": "tsx scripts/generate-sparse-plan.ts",
    "data:assign": "tsx scripts/generate-content-assignment.ts",
    "data:templates": "tsx scripts/generate-question-templates.ts",
    "data:patch:drafts": "tsx scripts/generate-subject-patch-files.ts",
    "data:patch:apply": "tsx scripts/apply-question-patches.ts",
    "tts:catalog": "tsx scripts/generate-static-tts-catalog.ts",
    "tts:generate:static": "npm --prefix backend run tts:generate-static --"
  },
  "keywords": [
    "education",
    "kids",
    "math"
  ],
  "author": "",
  "license": "ISC",
  "description": "Ứng dụng học tập vui nhộn cho học sinh tiểu học",
  "build": {
    "appId": "com.hochungkhoi.tieuhoc",
    "productName": "Hoc Hung Khoi Tieu Hoc",
    "icon": "public/icon.png",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/icon.png",
      "package.json"
    ],
    "extraMetadata": {
      "name": "hoc-hung-khoi",
      "productName": "Hoc Hung Khoi Tieu Hoc",
      "main": "electron/main.js"
    },
    "win": {
      "icon": "public/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "HocHungKhoi_Desktopapp-Win.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "HocHungKhoi_Desktopapp-Macbook.${ext}"
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "fflate": "^0.8.2",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "wait-on": "^9.0.5"
  }
}
