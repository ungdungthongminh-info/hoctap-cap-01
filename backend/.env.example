# Server
PORT=5000
NODE_ENV=development

# Database
DB_PATH=./data/hhk.db

# SePay Configuration
SEPAY_CLIENT_ID=SP-TEST-KV44A883
SEPAY_API_KEY=YOUR_SEPAY_SECRET_KEY
SEPAY_WEBHOOK_SECRET=YOUR_SEPAY_SECRET_KEY
SEPAY_ENVIRONMENT=sandbox
SEPAY_ACCOUNT=49312517
SEPAY_BANK_CODE=970416
SANDBOX_TEST_PLAN_ID=standard
SANDBOX_TEST_BILLING_CYCLE=monthly
SANDBOX_TEST_AMOUNT=2000

# JWT Secret (for authentication)
JWT_SECRET=your-secret-key-here-change-in-production

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# API
API_PREFIX=/api/v1

# Web Sales Total sync (Phase 1)
# Example: http://localhost:3900
WEB_TOTAL_BASE_URL=
# App id tren Web tong catalog (app-study-12 = Phan mem hoc tap khoi cap 01)
WEB_TOTAL_APP_ID=app-study-12
# Product map flat: "planId:billingCycle" -> productId (null = chua co / mien phi)
# Goi 599k co the map ve standard:yearly va/hoac standard_1year_3grade:yearly.
WEB_TOTAL_PRODUCT_MAP_JSON={"standard:monthly":"prod-study-month","standard:yearly":"prod-study-year","standard:lifetime":"prod-study-standard-lifetime","standard_1year_1grade:yearly":"standard_1year_1grade","standard_1year_3grade:yearly":"prod-study-year","premium:monthly":"prod-study-premium-month","premium:yearly":"prod-study-premium-year","premium:lifetime":"prod-study-premium-lifetime"}
# Optional in-memory bridge session TTL (default 7 days)
WEB_TOTAL_BRIDGE_SESSION_TTL_MS=604800000
