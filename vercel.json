{
  "framework": "vite",
  "buildCommand": "npm run build:web && npm --prefix backend run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "experimentalServices": {
    "frontend": {
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend/dist/index.js",
      "routePrefix": "/_/backend",
      "framework": "express"
    }
  }
}
